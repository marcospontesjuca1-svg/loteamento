# ── SQL Server ────────────────────────────────────────────────────────────────
DB_SERVER=10.0.0.10
DB_INSTANCE=SERV2012R2\\SWS
DB_USER=sa
DB_PASSWORD=SENHA_AQUI
DB_BDWIND=BDWind
DB_SCRWIND=SCRWind

# ── Agendamento (cron) ────────────────────────────────────────────────────────
# Padrão: a cada 1 hora  |  "*/30 * * * *" = a cada 30 min
CRON_SCHEDULE=0 * * * *

# ── Modo debug (true = exibe SQL executado) ───────────────────────────────────
DEBUG=false

# ── Export JSON estático → GitHub Pages ───────────────────────────────────────
# Token com permissão "Contents: Write" no repositório
# Gere em: GitHub → Settings → Developer settings → Personal access tokens
GH_TOKEN=ghp_SEU_TOKEN_AQUI
GH_OWNER=marcospontesjuca1-svg
GH_REPO=loteamento
